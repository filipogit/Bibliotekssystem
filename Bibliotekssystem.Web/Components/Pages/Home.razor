@page "/"
@rendermode InteractiveServer
@inject LibraryContext Db

<PageTitle>Bibliotekssystem – Hem</PageTitle>

<h1>📚 Välkommen till Bibliotekssystemet</h1>
<p class="lead">Hantera böcker, medlemmar och utlåning på ett ställe.</p>

<div class="row mt-4">
    <div class="col-md-3 mb-3">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h5 class="card-title">Böcker totalt</h5>
                <p class="card-text display-6">@totalBooks</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <h5 class="card-title">Tillgängliga böcker</h5>
                <p class="card-text display-6">@availableBooks</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <h5 class="card-title">Aktiva lån</h5>
                <p class="card-text display-6">@activeLoans</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-bg-danger">
            <div class="card-body">
                <h5 class="card-title">Försenade lån</h5>
                <p class="card-text display-6">@overdueLoans</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-3 mb-3">
        <div class="card text-bg-info">
            <div class="card-body">
                <h5 class="card-title">Medlemmar</h5>
                <p class="card-text display-6">@totalMembers</p>
            </div>
        </div>
    </div>
</div>

<h2 class="mt-4">Navigera till</h2>
<div class="d-flex gap-3 flex-wrap mt-2">
    <a href="/books" class="btn btn-outline-primary btn-lg">📖 Böcker</a>
    <a href="/members" class="btn btn-outline-secondary btn-lg">👤 Medlemmar</a>
    <a href="/loans" class="btn btn-outline-warning btn-lg">🔖 Utlåning</a>
</div>

@code {
    private int totalBooks;
    private int availableBooks;
    private int activeLoans;
    private int overdueLoans;
    private int totalMembers;

    protected override async Task OnInitializedAsync()
    {
        totalBooks = await Db.Books.CountAsync();
        availableBooks = await Db.Books.CountAsync(b => b.IsAvailable);
        activeLoans = await Db.Loans.CountAsync(l => l.ReturnDate == null);
        overdueLoans = await Db.Loans.CountAsync(l => l.ReturnDate == null && l.DueDate < DateTime.Now);
        totalMembers = await Db.Members.CountAsync();
    }
}

